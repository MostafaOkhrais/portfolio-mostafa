DirectoryIndex index.html
# ============================================================
#  Apache Configuration — Mostafa Khrais Portfolio
#  Performance · Security · SEO · Rate Limiting
# ============================================================

# -- Rewrite Engine --
RewriteEngine On


# ============================================================
#  SECURITY HEADERS
# ============================================================
<IfModule mod_headers.c>
  # Prevent MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Prevent clickjacking
  Header always set X-Frame-Options "DENY"

  # Enforce HTTPS (enable once SSL is active)
  # Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

  # Referrer policy
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Content Security Policy
  Header always set Content-Security-Policy "default-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:;"

  # Restrict feature APIs
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), fullscreen=(self)"

  # Disable server signature
  Header always unset X-Powered-By

  # Cross-Origin isolation
  Header always set Cross-Origin-Resource-Policy "same-origin"
  Header always set Cross-Origin-Opener-Policy "same-origin"
</IfModule>

# Hide Apache version
ServerSignature Off


# ============================================================
#  RATE LIMITING & DDoS MITIGATION
# ============================================================

# -- mod_evasive (requires the module to be loaded) --
# Uncomment below and adjust if mod_evasive is installed:
# <IfModule mod_evasive20.c>
#   DOSHashTableSize    3097
#   DOSPageCount        5
#   DOSSiteCount        50
#   DOSPageInterval     2
#   DOSSiteInterval     2
#   DOSBlockingPeriod   10
#   DOSLogDir           "/var/log/mod_evasive"
# </IfModule>

# -- mod_ratelimit — bandwidth throttling per client --
# Limits each client to 500 KB/s for the root URL
# <IfModule mod_ratelimit.c>
#   SetOutputFilter RATE_LIMIT
#   SetEnv rate-limit 500
# </IfModule>

# -- mod_reqtimeout — connection timeout hardening --
<IfModule mod_reqtimeout.c>
  RequestReadTimeout header=20-40,MinRate=500 body=30,MinRate=500
</IfModule>

# -- Block empty User-Agent (basic DDoS / bot filter) --
RewriteCond %{HTTP_USER_AGENT} ^-?$
RewriteRule ^ - [F,L]

# -- Block known bad bots / scanners --
RewriteCond %{HTTP_USER_AGENT} (ahrefs|majestic|seoanalyzer|screaming\ frog|acunetix|netsparker|wpscan|nmap|sqlmap) [NC]
RewriteRule ^ - [F,L]

# -- Prevent hotlinking of images --
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^https?://(www\.)?mostafakhrais\.dev [NC]
RewriteCond %{HTTP_REFERER} !^https?://localhost [NC]
RewriteRule \.(png|jpe?g|gif|webp|svg|ico)$ - [F,L]

# -- Limit request methods to safe verbs --
RewriteCond %{REQUEST_METHOD} !^(GET|HEAD|POST)$ [NC]
RewriteRule ^ - [F,L]

# -- Block access to hidden files (dotfiles) --
RewriteRule "(^|/)\.(?!well-known)" - [F]


# ============================================================
#  URL REWRITES & REDIRECTS
# ============================================================

DirectoryIndex index.html (clean URLs)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]

# Redirect /portfolio to /
RewriteRule ^portfolio$ / [R=301,L]

# Force HTTPS (uncomment after SSL is set up)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Redirect www to non-www (choose one)
# RewriteCond %{HTTP_HOST} ^www\.mostafakhrais\.dev [NC]
# RewriteRule ^ https://mostafakhrais.dev%{REQUEST_URI} [R=301,L]


# ============================================================
#  CACHING
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML: no cache (dynamic content)
  ExpiresByType text/html "access plus 0 seconds"

  # CSS + JS: 1 month
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"

  # Fonts: 1 year
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"

  # Images: 1 year
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# ETags for better cache validation
FileETag MTime Size


# ============================================================
#  COMPRESSION
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml font/ttf font/woff font/woff2 image/svg+xml
</IfModule>


# ============================================================
#  DIRECTORY PROTECTION
# ============================================================

# Deny access to internal directories
RedirectMatch 404 /\.git
RedirectMatch 404 /\.playwright-mcp

# Disable directory listing
Options -Indexes

# Deny access to sensitive files
<FilesMatch "\.(rar|zip|sql|md|log|env)$">
  Require all denied
</FilesMatch>


# ============================================================
#  CUSTOM ERROR PAGES
# ============================================================
ErrorDocument 404 /404.html
ErrorDocument 403 /403.html
ErrorDocument 500 /500.html


# ============================================================
#  PHP SECURITY (uncomment if PHP is used)
# ============================================================
# php_flag expose_php Off
# php_flag display_errors Off
# php_flag log_errors On
